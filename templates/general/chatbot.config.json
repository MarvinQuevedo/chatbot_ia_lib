{
  "botName": "Alex",
  "companyName": "Your Company",
  "roleDescription": "a helpful virtual assistant for our customers",

  "ai": {
    "primary": {
      "type": "ollama",
      "model": "llama3.2:8b",
      "baseUrl": "http://localhost:11434",
      "timeoutMs": 60000,
      "options": {
        "num_ctx": 4096,
        "temperature": 0.7
      }
    },
    "fallback": null
  },

  "orchestrator": {
    "maxToolCallsPerTurn": 5,
    "maxHistoryMessages": 20,
    "maxResponseLength": 2000
  },

  "session": {
    "ttlMs": 1800000,
    "maxHistoryMessages": 100
  },

  "integrations": {
    "timeoutMs": 10000,
    "maxRetries": 2
  },

  "outputFormat": "markdown",

  "server": {
    "port": 3000,
    "corsOrigins": ["http://localhost:*"]
  }
}
