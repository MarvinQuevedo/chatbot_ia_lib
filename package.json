{
  "name": "chatbot-ia-lib",
  "version": "0.1.0",
  "description": "A plug-and-play, AI-driven chatbot framework. Configure once, deploy for any business — without writing AI code.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./core": "./src/core/index.js",
    "./backends": "./src/backends/index.js"
  },
  "bin": {
    "chatbot-ia-lib": "./bin/cli.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .js",
    "dev": "node bin/cli.js"
  },
  "keywords": [
    "chatbot",
    "ai",
    "llm",
    "ollama",
    "framework",
    "business-automation"
  ],
  "author": "Marvin Quevedo",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.7.7",
    "better-sqlite3": "^11.5.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "handlebars": "^4.7.8",
    "inquirer": "^10.2.2",
    "openai": "^4.67.3",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.4",
    "vitest": "^2.1.4"
  }
}
